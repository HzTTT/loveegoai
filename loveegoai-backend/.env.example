# ==================== 应用配置 ====================
APP_NAME="Love Ego AI Backend"
APP_VERSION="1.0.0"
DEBUG=False
HOST=0.0.0.0
PORT=8000

# ==================== 安全配置 ====================
# 生成方法: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your_secret_key_here_MUST_CHANGE
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ==================== MongoDB Atlas ====================
# 1. 前往 https://cloud.mongodb.com 创建免费集群
# 2. 创建数据库用户，获取连接字符串
# 3. 在Network Access中添加服务器IP（或0.0.0.0/0允许所有）
MONGODB_URL=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=loveegoai

# ==================== 通义千问 LLM ====================
# 获取地址: https://dashscope.console.aliyun.com/apiKey
QWEN_API_KEY=your_qwen_api_key_here
QWEN_MODEL=qwen-plus
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ==================== Pinecone 向量数据库 ====================
# 获取地址: https://app.pinecone.io/
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=gcp-starter
PINECONE_INDEX_NAME=loveegoai-knowledge

# ==================== TTS 配置 ====================
TTS_VOICE=zh-CN-XiaoxiaoNeural

# ==================== CORS 配置 ====================
# 生产环境请替换为实际的前端域名
ALLOWED_ORIGINS=https://yourdomain.com,http://localhost:5174

# ==================== 文件存储 ====================
STATIC_DIR=./static
AUDIO_DIR=./static/audios
COVER_DIR=./static/letter_covers

# ==================== 信件生成配置 ====================
LETTER_GENERATION_TIME=00:00
